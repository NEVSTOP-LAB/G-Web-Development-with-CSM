	<VirtualInstrument CustomTitle="String to Boolean (CSM)" Id="ec6102714a704d49bf08e8f05e4b585f" Reentrancy="Stateful" xmlns="http://www.ni.com/LabVIEW.VI">
		<p.UserDescription xmlns="http://www.ni.com/PlatformFramework">If the input string is one of "1", "Active", "Affirmed", "Enable", "Established", "Existing", "Non-null", "On", "operational", "T", "True", "valid" , the output will be ture; if the input string is one of "0", "Abolished", "Close", "Disable", "F", "False", "Inactive", "Inoperative", "Invalid", "Locked", "Negated", "Nonexistent", "Off", "void" , the output will be false; otherwise, the outputs follows the default boolean control.</p.UserDescription>
